{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Feature Comparison Study: Impact of Heart Rate (HRV) Features on Drowsiness Detection\n",
    "\n",
    "Comparative analysis of classification performance with and without heart rate variability (HRV) features."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.model_selection import train_test_split, cross_val_score\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix, classification_report\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Set style\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (14, 6)\n",
    "\n",
    "print(\"Libraries loaded successfully!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load and Prepare Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "csv_path = '/home/karthik/Desktop/llm_eval/combined_participants.csv'\n",
    "df = pd.read_csv(csv_path)\n",
    "\n",
    "print(f\"Dataset loaded: {df.shape}\")\n",
    "print(f\"Drowsiness distribution:\")\n",
    "print(df['drowsiness_level'].value_counts().sort_index())\n",
    "\n",
    "# Encode target variable\n",
    "label_map = {'Low': 0, 'Moderate': 1, 'High': 2}\n",
    "df['target'] = df['drowsiness_level'].map(label_map)\n",
    "\n",
    "# Define feature sets\n",
    "eye_metrics = [\n",
    "    'metric_PERCLOS', 'metric_BlinkRate',\n",
    "    'blink_duration_mean', 'blink_duration_std', 'blink_duration_max',\n",
    "    'metric_YawnRate', 'metric_Entropy', 'metric_SteeringRate', 'metric_SDLP'\n",
    "]\n",
    "\n",
    "hrv_metrics = ['HRV_RMSSD', 'HRV_SD1']\n",
    "\n",
    "# Filter to available columns\n",
    "available_eye_metrics = [col for col in eye_metrics if col in df.columns]\n",
    "available_hrv_metrics = [col for col in hrv_metrics if col in df.columns]\n",
    "\n",
    "features_with_hrv = available_eye_metrics + available_hrv_metrics\n",
    "features_without_hrv = available_eye_metrics\n",
    "\n",
    "print(f\"\\nEye metrics ({len(available_eye_metrics)}): {available_eye_metrics}\")\n",
    "print(f\"\\nHRV metrics ({len(available_hrv_metrics)}): {available_hrv_metrics}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Helper Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def prepare_data(df, feature_list):\n",
    "    \"\"\"Prepare and clean data\"\"\"\n",
    "    X = df[feature_list].copy()\n",
    "    y = df['target'].copy()\n",
    "    \n",
    "    # Handle missing values\n",
    "    X = X.fillna(X.mean())\n",
    "    \n",
    "    # Standardize\n",
    "    scaler = StandardScaler()\n",
    "    X_scaled = scaler.fit_transform(X)\n",
    "    \n",
    "    return X_scaled, y, scaler\n",
    "\n",
    "def run_clustering_analysis(X_scaled, y, dataset_name):\n",
    "    \"\"\"Run PCA and KMeans clustering\"\"\"\n",
    "    # PCA 2D\n",
    "    pca = PCA(n_components=2)\n",
    "    X_pca = pca.fit_transform(X_scaled)\n",
    "    \n",
    "    # PCA variance\n",
    "    pca_variance = pca.explained_variance_ratio_.sum()\n",
    "    \n",
    "    # KMeans\n",
    "    kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)\n",
    "    clusters = kmeans.fit_predict(X_scaled)\n",
    "    \n",
    "    return {\n",
    "        'pca': pca,\n",
    "        'X_pca': X_pca,\n",
    "        'pca_variance': pca_variance,\n",
    "        'kmeans': kmeans,\n",
    "        'clusters': clusters\n",
    "    }\n",
    "\n",
    "def run_classification_models(X_scaled, y):\n",
    "    \"\"\"Train and evaluate classification models\"\"\"\n",
    "    # Train-test split\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X_scaled, y, test_size=0.2, random_state=42, stratify=y\n",
    "    )\n",
    "    \n",
    "    models = {\n",
    "        'Logistic Regression': LogisticRegression(max_iter=1000, random_state=42),\n",
    "        'Random Forest': RandomForestClassifier(n_estimators=100, random_state=42),\n",
    "        'Gradient Boosting': GradientBoostingClassifier(n_estimators=100, random_state=42)\n",
    "    }\n",
    "    \n",
    "    results = {}\n",
    "    for name, model in models.items():\n",
    "        # Train\n",
    "        model.fit(X_train, y_train)\n",
    "        \n",
    "        # Predict\n",
    "        y_pred = model.predict(X_test)\n",
    "        \n",
    "        # Metrics\n",
    "        accuracy = accuracy_score(y_test, y_pred)\n",
    "        precision = precision_score(y_test, y_pred, average='weighted', zero_division=0)\n",
    "        recall = recall_score(y_test, y_pred, average='weighted', zero_division=0)\n",
    "        f1 = f1_score(y_test, y_pred, average='weighted', zero_division=0)\n",
    "        \n",
    "        results[name] = {\n",
    "            'model': model,\n",
    "            'accuracy': accuracy,\n",
    "            'precision': precision,\n",
    "            'recall': recall,\n",
    "            'f1': f1,\n",
    "            'y_pred': y_pred,\n",
    "            'y_test': y_test,\n",
    "            'X_test': X_test\n",
    "        }\n",
    "    \n",
    "    return results\n",
    "\n",
    "print(\"Helper functions defined!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Analysis WITH HRV Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"ANALYSIS WITH HRV FEATURES\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Prepare data\n",
    "X_with_hrv, y, scaler_with_hrv = prepare_data(df, features_with_hrv)\n",
    "print(f\"\\nFeatures: {len(features_with_hrv)} ({len(available_eye_metrics)} eye + {len(available_hrv_metrics)} HRV)\")\n",
    "print(f\"Data shape: {X_with_hrv.shape}\")\n",
    "\n",
    "# Clustering\n",
    "cluster_results_with_hrv = run_clustering_analysis(X_with_hrv, y, \"WITH HRV\")\n",
    "print(f\"\\nPCA 2D Variance Explained: {cluster_results_with_hrv['pca_variance']:.2%}\")\n",
    "\n",
    "# Classification\n",
    "class_results_with_hrv = run_classification_models(X_with_hrv, y)\n",
    "print(f\"\\nClassification Results:\")\n",
    "for name, results in class_results_with_hrv.items():\n",
    "    print(f\"  {name}:\")\n",
    "    print(f\"    Accuracy:  {results['accuracy']:.4f}\")\n",
    "    print(f\"    Precision: {results['precision']:.4f}\")\n",
    "    print(f\"    Recall:    {results['recall']:.4f}\")\n",
    "    print(f\"    F1-Score:  {results['f1']:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Analysis WITHOUT HRV Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"ANALYSIS WITHOUT HRV FEATURES\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Prepare data\n",
    "X_without_hrv, y, scaler_without_hrv = prepare_data(df, features_without_hrv)\n",
    "print(f\"\\nFeatures: {len(features_without_hrv)} (eye metrics only)\")\n",
    "print(f\"Data shape: {X_without_hrv.shape}\")\n",
    "\n",
    "# Clustering\n",
    "cluster_results_without_hrv = run_clustering_analysis(X_without_hrv, y, \"WITHOUT HRV\")\n",
    "print(f\"\\nPCA 2D Variance Explained: {cluster_results_without_hrv['pca_variance']:.2%}\")\n",
    "\n",
    "# Classification\n",
    "class_results_without_hrv = run_classification_models(X_without_hrv, y)\n",
    "print(f\"\\nClassification Results:\")\n",
    "for name, results in class_results_without_hrv.items():\n",
    "    print(f\"  {name}:\")\n",
    "    print(f\"    Accuracy:  {results['accuracy']:.4f}\")\n",
    "    print(f\"    Precision: {results['precision']:.4f}\")\n",
    "    print(f\"    Recall:    {results['recall']:.4f}\")\n",
    "    print(f\"    F1-Score:  {results['f1']:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Comparison Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comparison table\n",
    "comparison_data = []\n",
    "\n",
    "for model_name in class_results_with_hrv.keys():\n",
    "    with_hrv = class_results_with_hrv[model_name]\n",
    "    without_hrv = class_results_without_hrv[model_name]\n",
    "    \n",
    "    accuracy_diff = with_hrv['accuracy'] - without_hrv['accuracy']\n",
    "    \n",
    "    comparison_data.append({\n",
    "        'Model': model_name,\n",
    "        'WITH HRV Accuracy': f\"{with_hrv['accuracy']:.4f}\",\n",
    "        'WITHOUT HRV Accuracy': f\"{without_hrv['accuracy']:.4f}\",\n",
    "        'Accuracy Difference': f\"{accuracy_diff:+.4f}\",\n",
    "        'Impact (%)': f\"{(accuracy_diff/without_hrv['accuracy']*100):+.2f}%\" if without_hrv['accuracy'] > 0 else \"N/A\"\n",
    "    })\n",
    "\n",
    "comparison_df = pd.DataFrame(comparison_data)\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"ACCURACY COMPARISON\")\n",
    "print(\"=\"*80)\n",
    "print(comparison_df.to_string(index=False))\n",
    "\n",
    "# Clustering comparison\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"CLUSTERING COMPARISON (PCA 2D Variance Explained)\")\n",
    "print(\"=\"*80)\n",
    "pca_diff = cluster_results_with_hrv['pca_variance'] - cluster_results_without_hrv['pca_variance']\n",
    "print(f\"WITH HRV:    {cluster_results_with_hrv['pca_variance']:.2%}\")\n",
    "print(f\"WITHOUT HRV: {cluster_results_without_hrv['pca_variance']:.2%}\")\n",
    "print(f\"Difference:  {pca_diff:+.2%}\")"
   ]
  },
